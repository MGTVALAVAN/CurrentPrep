# CurrentPrep – Environment Variables Template
# Copy this file to .env.local and fill in real values.
#
# Required vars are marked [REQUIRED], optional ones [OPTIONAL].

# ── NextAuth ────────────────────────────────────────────────────────────
# [REQUIRED] Full URL of your app
NEXTAUTH_URL=http://localhost:3000

# [REQUIRED] Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Supabase ────────────────────────────────────────────────────────────
# [REQUIRED] Your Supabase project URL (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase anon/public key (client-side, respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# [REQUIRED for server] Supabase service role key (bypasses RLS, server-only!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Google OAuth ────────────────────────────────────────────────────────
# [OPTIONAL] Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Gemini AI ───────────────────────────────────────────────────────────
# [REQUIRED] Google AI Studio API key for content generation
GEMINI_API_KEY=your-gemini-api-key

# ── Cron Secret ─────────────────────────────────────────────────────────
# [REQUIRED] Generate with: openssl rand -base64 32
# Used to authenticate cron job requests to /api/epaper/generate and /api/current-affairs/update
CRON_SECRET=

# ── Mailer Settings ─────────────────────────────────────────────────────
# [OPTIONAL] SMTP credentials for email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# [OPTIONAL] Recipient for contact form submissions
CONTACT_EMAIL_TO=your-email@gmail.com

# ── Razorpay ────────────────────────────────────────────────────────────
# [OPTIONAL] Payment integration (required for premium features)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
